[sqlfluff]
# DuckDB dialect; lint logic/capitalisation/references only — sqlfmt owns layout.
dialect = duckdb
templater = jinja
exclude_rules = layout
max_line_length = 100

[sqlfluff:templater:jinja]
# Stub dbt's ref()/source()/config() so we don't need to compile via dbt.
apply_dbt_builtins = true

[sqlfluff:rules:capitalisation.keywords]
capitalisation_policy = lower

[sqlfluff:rules:capitalisation.identifiers]
capitalisation_policy = lower
