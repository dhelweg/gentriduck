[sqlfluff]
# DuckDB dialect; lint logic/capitalisation/references only -- sqlfmt owns layout.
# structure.column_order (ST06) excluded: interleaved CAST/CASE columns follow semantic
# ordering from the staging schema contract; reordering would harm readability.
dialect = duckdb
templater = jinja
exclude_rules = layout, structure.column_order
max_line_length = 100
large_file_skip_byte_limit = 0

[sqlfluff:templater:jinja]
# Stub dbt's ref()/source()/config() so we don't need to compile via dbt.
apply_dbt_builtins = true

[sqlfluff:templater:jinja:macros]
# run_query stub: returns an object with a columns[0][0] accessor that yields 0.
# This makes stg_osm_poi.sql template to the zero-row stub branch, which is valid SQL.
run_query = "{% macro run_query(q) %}{% set ns = namespace() %}{% set ns.result = '' %}{{ ns }}{% endmacro %}"

[sqlfluff:templater:jinja:context]
# Default value for file_count used in stg_osm_poi.sql graceful-degradation logic.
# SQLFluff templates the else-branch (zero-row stub) which is always valid SQL.
file_count = 0
execute = False
# Stub for generic dbt test macros — 'model' is injected by dbt at runtime.
model = gentriduck__main__test_model

[sqlfluff:rules:capitalisation.keywords]
capitalisation_policy = lower

[sqlfluff:rules:capitalisation.identifiers]
capitalisation_policy = lower
