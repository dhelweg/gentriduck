# Copy to .env (gitignored) and fill in as needed. No secrets are required for local
# DuckDB development; these are only used later for hosting / MotherDuck.

# MotherDuck (Epic F — optional, free tier)
# MOTHERDUCK_TOKEN=

# dbt: keep the profile repo-local so the global ~/.dbt is untouched.
DBT_PROFILES_DIR=transform
